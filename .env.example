SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=

# MySQL container credentials (used by docker-compose.yml)
MYSQL_USER=chatuser
MYSQL_PASSWORD=chatpass
MYSQL_ROOT_PASSWORD=rootpass

# JWT secret (Base64 decode >= 32 bytes). Replace in real environments.
APP_JWT_SECRET=MDEyMzQ1Njc4OUFCQ0RFRjAxMjM0NTY3ODlBQkNERUY=

# Optional integrations
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
GOOGLE_CLIENT_ID=7308013918-s6pboomi1maisaq1ebrm12lutubdder9.apps.googleusercontent.com
APP_AUDIT_ADMIN_PRIVATE_KEY_PEM=

# Frontend build arg (docker-compose.full.yml)
BACKEND_BASE_URL=http://localhost:8080/TejeChat
